#moviescontroller.js
const movies = require("../data/movies.json");

exports.getAllMovies = (req, res) => {
  res.json(movies);
};

exports.getMovieById = (req, res) => {
  const movie = movies.find(m => m.id === parseInt(req.params.id));

  if (!movie) {
    return res.status(404).json({ message: "Movie not found" });
  }

  res.json(movie);
};
