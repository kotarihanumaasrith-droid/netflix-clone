# server.js backend
const express = require("express");
const cors = require("cors");

const movieRoutes = require("./routes/movies");

const app = express();
app.use(cors());
app.use(express.json());

app.use("/api/movies", movieRoutes);

const PORT = 5000;

app.listen(PORT, () => {
  console.log(`Server running at http://localhost:${PORT}`);
});
